# Railway provides this automatically — no need to set manually
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Only used for local dev (Railway ignores these when DATABASE_URL is set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=moviroo

# Railway sets this automatically, but you can override
PORT=3000
NODE_ENV=production

# Required secrets — add these in Railway Variables dashboard
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_INVITE_SECRET=change_me

# Frontend URLs (CORS)
FRONTEND_URL=https://admin.moviroo.tn
BACKEND_URL=https://your-railway-app.up.railway.app/api

# WebAuthn / Passkeys
WEBAUTHN_RP_ID=moviroo.tn
WEBAUTHN_ORIGIN=https://moviroo.tn

# SMTP
MAIL_MAILER=smtp
MAIL_HOST=ssl0.ovh.net
MAIL_PORT=587
MAIL_USERNAME=no-reply@moviroo.tn
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@moviroo.tn
MAIL_FROM_NAME="Moviroo"

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=your-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@...
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Cloudinary
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# External APIs
ML_API_URL=https://your-ml-api.railway.app
ML_CONFIG_API_URL=https://your-ml-config.railway.app
CHATBOT_API_URL=https://your-chatbot.railway.app

# Optional
DEEPL_API_KEY=...
MAPBOX_ACCESS_TOKEN=pk...
HUGGINGFACE_API_KEY=hf_...
